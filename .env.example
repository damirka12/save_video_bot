# Скопируй в .env и заполни своими значениями:
#   cp .env.example .env
BOT_TOKEN=токен_от_BotFather
ADMIN_ID=твой_telegram_id

# Путь к БД (общая папка data/ для бота и админки)
DB_PATH=data/users.db

# ─── Локальный Bot API сервер (снимает лимит 50 МБ → 2000 МБ) ───
# Получить API_ID и API_HASH: https://my.telegram.org → API development tools
# ВАЖНО: после первого запуска один раз вызвать logOut (см. README/инструкцию)
USE_LOCAL_SERVER=true
TELEGRAM_API_ID=твой_api_id
TELEGRAM_API_HASH=твой_api_hash
LOCAL_SERVER_URL=http://telegram-api:8081

# Веб-админка для редактирования текстов
ADMIN_PANEL_USER=admin
ADMIN_PANEL_PASSWORD=придумай_надёжный_пароль
ADMIN_PORT=8080

# Лимиты (необязательно — есть значения по умолчанию)
# MAX_VIDEO_DURATION=3600         # макс. длина видео в секундах (0 — без лимита)
# MAX_CONCURRENT_DOWNLOADS=3      # сколько загрузок идёт одновременно
# URL_CACHE_TTL=3600             # сколько живёт ссылка в кэше (сек)
# URL_CACHE_MAX=1000            # макс. ссылок в кэше
