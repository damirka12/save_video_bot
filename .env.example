# Скопируй в .env и заполни своими значениями:
#   cp .env.example .env
BOT_TOKEN=токен_от_BotFather
ADMIN_ID=твой_telegram_id

# Путь к БД (общая папка data/ для бота и админки)
DB_PATH=data/users.db

# Веб-админка для редактирования текстов
ADMIN_PANEL_USER=admin
ADMIN_PANEL_PASSWORD=придумай_надёжный_пароль
ADMIN_PORT=8080
